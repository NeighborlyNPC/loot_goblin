			},
			"scripts": {
				"animate": [
					"ctrl_motion"
				],
				"pre_animation": [
					"variable.name = query.has_property('loot:name') ? query.property('loot:name') : -1;",
					"variable.do_anim2 = math.random(0, 100) < 0.5 ? 1.0 : 0.0;"
				]
			},
			"render_controllers": [
				"controller.render.goblin"
			]
		}
	}
}
