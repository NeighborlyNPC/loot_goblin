{
	"format_version": "1.8.0",
	"render_controllers": {
		"controller.render.goblin": {
			"geometry": "geometry.default",
			"materials": [
				{ "*": "material.default" }
			],
			"textures": [
				"variable.name >= 0 ? array.names[variable.name] : texture.poppy"
			],
			"arrays": {
				"textures": {
					"array.names": [
						"texture.poppy",    "texture.tristana",
						"texture.malvah",   "texture.smug",
						"texture.gobu",     "texture.jackie"
					]
				}
			}
		}
	}
}
